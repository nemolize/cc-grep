{
  "name": "cc-grep",
  "version": "0.1.0",
  "description": "Cross-project full-text search CLI over Claude Code session transcripts. Run with npx.",
  "keywords": [
    "claude",
    "claude-code",
    "grep",
    "search",
    "transcript",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "bin": {
    "cc-grep": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node --input-type=module -e \"import {rmSync} from 'node:fs'; rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . && prettier --check .",
    "fix": "eslint . --fix && prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
